# Copy to .env and fill in. All values shown are the defaults.

DATABASE_URL=postgresql+psycopg://stoa:stoa@localhost:5433/stoa

# Required for the /api/chat endpoint (or authenticate once with `ant auth login`)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional. Without it, retrieval falls back to Postgres full-text search.
# With it, passages are embedded (voyage-3.5) and retrieval uses pgvector similarity.
# VOYAGE_API_KEY=pa-...

ANTHROPIC_MODEL=claude-opus-4-8
CHAT_EFFORT=medium
