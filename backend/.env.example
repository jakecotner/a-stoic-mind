# Copy to .env and fill in. All values shown are the defaults.

DATABASE_URL=postgresql+psycopg://stoa:stoa@localhost:5433/stoa

# Required for the /api/chat endpoint (or authenticate once with `ant auth login`)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional. Without it, retrieval falls back to Postgres full-text search.
# With it, passages are embedded (voyage-3.5) and retrieval uses pgvector similarity.
# VOYAGE_API_KEY=pa-...

ANTHROPIC_MODEL=claude-opus-4-8
CHAT_EFFORT=medium

# Auth: signs JWT session cookies. Generate a real one for any shared deployment,
# e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET=dev-only-change-me
# Set true when serving over HTTPS so the session cookie is Secure.
AUTH_COOKIE_SECURE=false
